---
import Base from "@layouts/Base.astro";
import Kickoff from "@components/Kickoff.astro";
import NavCard from "@components/NavCard.astro";
import Button from "@components/Button.astro"

import geroPhoto from "@images/cgg/geraldton_feature.jpg"
import passStEmus from "@images/cgg/pass-st-emus/passStEmus.jpg"
import alexStRoundabout from "@images/cgg/alexanderStRoundabout.jpg"
import edithCowan from "@images/cgg/edith-cowan-statue/PXL_20260225_061444023.PORTRAIT.jpg"
import narelle from "@images/cgg/cyclone-narelle/BOM16-9.png"
---

<Base title="City of Greater Geraldton" description="The homepage for my CGG updates">
    <Kickoff contentAlign="center" backgroundImage={geroPhoto} backgroundAlt="A hand drawn building.">
        <h1>City of Greater Geraldton</h1>
        <p>This page is where I will provide community updates in regards to the City of Greater Geraldton</p>
    </Kickoff>
    <NavCard
        imageSide="right"
        imageSrc={narelle}
        imageAlt="A map of the path of a cyclone along the coast of Western Australia"
    >
        <h2>Tropical Cyclone Narelle</h2>
        <p>
            A postmortem of the effects of Tropical Cyclone Narelle after it passed through Geraldton
        </p>
        <Button href="cgg/cyclone-narelle">View Here</Button>
    </NavCard>
    <NavCard
        imageSide="left"
        imageSrc={edithCowan}
        imageAlt="A photo of a statue of a lady in front of a building that says COURTHOUSE"
    >
        <h2>Unveiling of the Edith Cowan Statue</h2>
        <p>
            After many months of delays in transit, the statue of Edith Dirksey Cowan, the first woman in Australia to serve as a member of parliament, has been erected in her square opposite the courtyard.
        </p>
        <Button href="cgg/edith-cowan-statue">View Here</Button>
    </NavCard>
    <NavCard
        imageSide="right"
        imageSrc={passStEmus}
        imageAlt="A photo of metalic emus on a roundabout"
    >
        <h2>Emus of Pass St Roundabout</h2>
        <p>
            During the reconstruction of the Pass St roundabout next to Adams Store,<br/>
            the City of Greater Geraldton removed the metalic emus from the<br/>
            roundabout due to safety concerns, yet residents would like to see<br/>
            their return.
        </p>
        <Button href="cgg/pass-st-emus">View Here</Button>
    </NavCard>
    <NavCard
        imageSide="left"
        imageSrc={alexStRoundabout}
        imageAlt="A photo of metalic emus on a roundabout"
    >
        <h2>Alexander Street Roundabout</h2>
        <p>
            The City of Greater Geraldton has proposed to construct a roundabout<br/>
            in Utakarra that connects Flores Road, Horwood Road, and Alexander<br/>
            Street, replacing the two T intersections.
        </p>
        <h3>Page Coming Soon</h3>
    </NavCard>
</Base>
<style>
    h3 {
        text-decoration: underline;
    }
</style>